---
// DocLayout.astro — The main layout for book pages.
// All doc pages are rendered through src/pages/docs/[...slug].astro which calls
// render() and passes typed props directly.  The `frontmatter` field is kept for
// backward-compatibility in case a markdown file uses the legacy `layout:` directive.

import type { MarkdownHeading } from "astro";
import "../styles/global.css";
import { navGroups, allPages, type NavItem } from "../nav";

// ------------------------------------------------------------------
// Props interface — fully typed.
//
// title        — page title shown in <title> and as the H1.  Required.
// description  — meta description for SEO.  Optional.
// headings     — array of headings extracted by render(), used for the
//                right-side Table of Contents.  Uses Astro's built-in
//                MarkdownHeading type: { depth, slug, text }.
// frontmatter  — legacy: Astro injects this when a .md file sets
//                `layout: ../../layouts/DocLayout.astro` in its frontmatter.
//                Prefer passing title/description directly instead.
// ------------------------------------------------------------------
interface Props {
  title: string;
  description?: string;
  headings?: MarkdownHeading[];
  /** @deprecated pass title/description directly instead */
  frontmatter?: {
    title?: string;
    description?: string;
  };
}

const { frontmatter, headings = [] } = Astro.props;
// frontmatter props are only present when using the legacy layout directive
const title = Astro.props.title ?? frontmatter?.title ?? "Book";
const description = Astro.props.description ?? frontmatter?.description ?? "";

const currentPath = Astro.url.pathname.replace(/\/$/, "");

const currentIndex = allPages.findIndex((p) => p.href === currentPath);
const prevPage: NavItem | undefined = currentIndex > 0 ? allPages[currentIndex - 1] : undefined;
const nextPage: NavItem | undefined =
  currentIndex < allPages.length - 1 ? allPages[currentIndex + 1] : undefined;

const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Compiler in Rust</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <!-- NAVBAR -->
    <nav class="navbar">
      <!-- navbar__inner centers all navbar content within the 1920px max-width -->
      <div class="navbar__inner">
        <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle menu">☰</button>
        <a href="/" class="navbar__logo">Compiler<span>Book</span> 🦀</a>
        <nav class="navbar__nav">
          <a href="/docs/getting-started">Guide</a>
          <a href="https://github.com/MrBns/compiler-book-rust" target="_blank">GitHub</a>
        </nav>
        <div class="navbar__right">
          <!-- Theme dropdown: Light / Dark / Device -->
          <div class="theme-dropdown" id="themeDropdown">
            <button class="theme-dropdown__trigger" id="themeDropdownTrigger" aria-haspopup="true" aria-expanded="false" aria-label="Select color theme">
              <span id="themeDropdownIcon">💻</span>
              <span id="themeDropdownLabel">Device</span>
              <span class="theme-dropdown__chevron">▾</span>
            </button>
            <div class="theme-dropdown__menu" id="themeDropdownMenu" role="menu">
              <button class="theme-dropdown__item" data-mode="light"  role="menuitem">☀️ Light</button>
              <button class="theme-dropdown__item" data-mode="dark"   role="menuitem">🌙 Dark</button>
              <button class="theme-dropdown__item" data-mode="device" role="menuitem">💻 Device</button>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <div class="layout">
      <!-- SIDEBAR -->
      <aside class="sidebar" id="sidebar">
        {navGroups.map((group) => (
          <div class="sidebar__group">
            <span class="sidebar__group-title">{group.title}</span>
            {group.items.map((item) => (
              <a
                href={item.href}
                class={`sidebar__link${item.href === currentPath ? " active" : ""}`}
              >
                {item.title}
              </a>
            ))}
          </div>
        ))}
      </aside>

      <!-- MAIN CONTENT -->
      <main class="main">
        <article class="content">
          <slot />

          <!-- Prev / Next navigation -->
          <nav class="page-nav">
            {prevPage ? (
              <a href={prevPage.href} class="page-nav__btn">
                <span class="page-nav__label">← Previous</span>
                <span class="page-nav__title">{prevPage.title}</span>
              </a>
            ) : <div />}
            {nextPage ? (
              <a href={nextPage.href} class="page-nav__btn page-nav__btn--next">
                <span class="page-nav__label">Next →</span>
                <span class="page-nav__title">{nextPage.title}</span>
              </a>
            ) : <div />}
          </nav>
        </article>
      </main>

      <!-- RIGHT TOC -->
      {tocHeadings.length > 0 && (
        <aside class="toc">
          <p class="toc__title">≡ On This Page</p>
          <ul class="toc__list">
            {tocHeadings.map((h) => (
              <li class={h.depth === 3 ? "h3" : ""}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </aside>
      )}
    </div>

    <script>
      const html = document.documentElement;
      const dropdown = document.getElementById("themeDropdown");
      const trigger  = document.getElementById("themeDropdownTrigger");
      const icon     = document.getElementById("themeDropdownIcon");
      const label    = document.getElementById("themeDropdownLabel");
      const items    = document.querySelectorAll<HTMLButtonElement>(".theme-dropdown__item");

      const MODE_META: Record<string, { icon: string; label: string }> = {
        light:  { icon: "☀️",  label: "Light"  },
        dark:   { icon: "🌙",  label: "Dark"   },
        device: { icon: "💻",  label: "Device" },
      };

      function applyMode(mode: string) {
        const meta = MODE_META[mode] ?? MODE_META.device;
        if (mode === "device") {
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          html.setAttribute("data-theme", prefersDark ? "dark" : "light");
        } else {
          html.setAttribute("data-theme", mode);
        }
        if (icon)  icon.textContent  = meta.icon;
        if (label) label.textContent = meta.label;
        items.forEach((btn) => btn.classList.toggle("active", btn.dataset.mode === mode));
      }

      // Restore saved preference (default: device)
      const saved = localStorage.getItem("theme-mode") ?? "device";
      applyMode(saved);

      // Open / close dropdown
      trigger?.addEventListener("click", (e) => {
        e.stopPropagation();
        dropdown?.classList.toggle("open");
        trigger.setAttribute("aria-expanded", String(dropdown?.classList.contains("open") ?? false));
      });

      // Select a mode
      items.forEach((btn) => {
        btn.addEventListener("click", () => {
          const mode = btn.dataset.mode ?? "device";
          localStorage.setItem("theme-mode", mode);
          applyMode(mode);
          dropdown?.classList.remove("open");
          trigger?.setAttribute("aria-expanded", "false");
        });
      });

      // Close on outside click
      document.addEventListener("click", (e) => {
        if (dropdown?.classList.contains("open") && !dropdown.contains(e.target as Node)) {
          dropdown.classList.remove("open");
          trigger?.setAttribute("aria-expanded", "false");
        }
      });

      const sidebar = document.getElementById("sidebar");
      const sidebarToggle = document.getElementById("sidebarToggle");
      sidebarToggle?.addEventListener("click", () => {
        sidebar?.classList.toggle("open");
      });
      document.addEventListener("click", (e) => {
        if (sidebar?.classList.contains("open")) {
          if (!sidebar.contains(e.target as Node) && e.target !== sidebarToggle) {
            sidebar.classList.remove("open");
          }
        }
      });

      const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".toc__list a");
      if (tocLinks.length > 0) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                tocLinks.forEach((l) => l.classList.remove("active"));
                const id = entry.target.id;
                const link = document.querySelector<HTMLAnchorElement>(`.toc__list a[href="#${id}"]`);
                link?.classList.add("active");
              }
            });
          },
          { rootMargin: "-80px 0px -70% 0px" }
        );
        document.querySelectorAll("h2[id], h3[id]").forEach((h) => observer.observe(h));
      }
    </script>
  </body>
</html>
