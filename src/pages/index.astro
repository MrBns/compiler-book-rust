---
// Home page — Introduction to the book
import "../styles/global.css";

const chapters = [
  { num: "Chapter 0", title: "Getting Started", href: "/docs/getting-started", desc: "Set up your Rust project and understand what we will build." },
  { num: "Chapter 1", title: "What is a Compiler?", href: "/docs/what-is-compiler", desc: "Learn the big picture. What does a compiler do, step by step?" },
  { num: "Chapter 2", title: "Our Project Plan", href: "/docs/project-plan", desc: "Design the language we will compile and pick TypeScript as our target." },
  { num: "Chapter 3", title: "Building the Lexer", href: "/docs/lexer-build", desc: "Turn raw source code text into a list of tokens using Rust." },
  { num: "Chapter 4", title: "Building the Parser", href: "/docs/parser-build", desc: "Turn tokens into a tree structure called an AST." },
  { num: "Chapter 5", title: "Semantic Analysis", href: "/docs/semantic", desc: "Check for mistakes in the code before we generate output." },
  { num: "Chapter 6", title: "Generating TypeScript", href: "/docs/codegen-typescript", desc: "Walk the AST and produce working TypeScript code." },
  { num: "Chapter 7", title: "Putting It All Together", href: "/docs/putting-together", desc: "Connect all pieces and run our compiler end-to-end." },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Compiler in Rust — Book</title>
    <meta name="description" content="Learn how to build a compiler in Rust. Easy English, lots of code examples." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <!-- Navbar -->
    <nav class="navbar">
      <!-- navbar__inner provides the flex row layout (logo | links | theme toggle) -->
      <div class="navbar__inner">
        <a href="/" class="navbar__logo">Compiler<span>Book</span> 🦀</a>
        <nav class="navbar__nav">
          <a href="/docs/getting-started">Guide</a>
          <a href="https://github.com/MrBns/compiler-book-rust" target="_blank">GitHub</a>
        </nav>
        <div class="navbar__right">
          <!-- theme dropdown: shows current mode (icon + label + chevron); opens panel on click -->
          <div class="theme-dropdown" id="themeDropdown">
            <button class="theme-dropdown__trigger" id="themeDropdownTrigger" aria-haspopup="true" aria-expanded="false" aria-label="Select color theme">
              <span id="themeDropdownIcon">💻</span>
              <span id="themeDropdownLabel">Device</span>
              <span class="theme-dropdown__chevron">▾</span>
            </button>
            <div class="theme-dropdown__menu" id="themeDropdownMenu" role="menu">
              <button class="theme-dropdown__item" data-mode="light" role="menuitem">☀️ Light</button>
              <button class="theme-dropdown__item" data-mode="dark"  role="menuitem">🌙 Dark</button>
              <button class="theme-dropdown__item" data-mode="device" role="menuitem">💻 Device</button>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <!-- Hero section -->
    <section class="hero" style="margin-top: var(--nav-height)">
      <div class="hero__badge">🦀 Written for Beginners</div>
      <h1 class="hero__title">
        Making a<br /><span>Compiler</span> in Rust
      </h1>
      <p class="hero__subtitle">
        A beginner-friendly book. You will learn how to build a real compiler in Rust —
        step by step — that turns your own language into TypeScript.
        Easy English, lots of code, lots of comments.
      </p>
      <div class="hero__cta">
        <a href="/docs/getting-started" class="btn btn--primary">📖 Start Reading</a>
        <a href="https://github.com/MrBns/compiler-book-rust" class="btn btn--outline" target="_blank">⭐ GitHub</a>
      </div>
    </section>

    <!-- Chapter cards -->
    <div class="chapter-grid">
      {chapters.map((c) => (
        <a href={c.href} class="chapter-card">
          <div class="chapter-card__num">{c.num}</div>
          <div class="chapter-card__title">{c.title}</div>
          <div class="chapter-card__desc">{c.desc}</div>
        </a>
      ))}
    </div>

    <script>
      const html = document.documentElement;
      const dropdown = document.getElementById("themeDropdown");
      const trigger  = document.getElementById("themeDropdownTrigger");
      const icon     = document.getElementById("themeDropdownIcon");
      const label    = document.getElementById("themeDropdownLabel");
      const items    = document.querySelectorAll<HTMLButtonElement>(".theme-dropdown__item");

      const MODE_META: Record<string, { icon: string; label: string }> = {
        light:  { icon: "☀️",  label: "Light"  },
        dark:   { icon: "🌙",  label: "Dark"   },
        device: { icon: "💻",  label: "Device" },
      };

      function applyMode(mode: string) {
        const meta = MODE_META[mode] ?? MODE_META.device;
        if (mode === "device") {
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          html.setAttribute("data-theme", prefersDark ? "dark" : "light");
        } else {
          html.setAttribute("data-theme", mode);
        }
        if (icon)  icon.textContent  = meta.icon;
        if (label) label.textContent = meta.label;
        items.forEach((btn) => btn.classList.toggle("active", btn.dataset.mode === mode));
      }

      // Restore saved preference (default: device)
      const saved = localStorage.getItem("theme-mode") ?? "device";
      applyMode(saved);

      // Open / close dropdown
      trigger?.addEventListener("click", (e) => {
        e.stopPropagation();
        dropdown?.classList.toggle("open");
        trigger.setAttribute("aria-expanded", String(dropdown?.classList.contains("open") ?? false));
      });

      // Select a mode
      items.forEach((btn) => {
        btn.addEventListener("click", () => {
          const mode = btn.dataset.mode ?? "device";
          localStorage.setItem("theme-mode", mode);
          applyMode(mode);
          dropdown?.classList.remove("open");
          trigger?.setAttribute("aria-expanded", "false");
        });
      });

      // Close on outside click
      document.addEventListener("click", (e) => {
        if (dropdown?.classList.contains("open") && !dropdown.contains(e.target as Node)) {
          dropdown.classList.remove("open");
          trigger?.setAttribute("aria-expanded", "false");
        }
      });
    </script>
  </body>
</html>

